<Window x:Class="UMADOverlay.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:v="clr-namespace:UMADOverlay.Views"
        xmlns:cv="clr-namespace:UMADOverlay.Converters"
        Title="UMAD Overlay"
        Width="{Binding WindowWidth, Mode=TwoWay}"
        Height="{Binding WindowHeight, Mode=TwoWay}"
        MinWidth="300" MinHeight="400"
        MaxWidth="800" MaxHeight="1000"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize">

    <Window.Resources>
        <cv:BoolToVisibilityConverter x:Key="BoolVis"/>
        <cv:BoolToVisibilityConverter x:Key="InvBoolVis" Invert="True"/>
        <cv:ColorToBrushConverter    x:Key="ColorToBrush"/>

        <SolidColorBrush x:Key="DragBrush"     Color="#0a0a0a"/>
        <SolidColorBrush x:Key="YellowBrush"   Color="#FFCC00"/>
        <SolidColorBrush x:Key="BlueBrush"      Color="#4DADFF"/>
        <SolidColorBrush x:Key="BorderBrush"    Color="#444444"/>
        <SolidColorBrush x:Key="MenuBgBrush"    Color="#252525"/>
        <SolidColorBrush x:Key="TextSubBrush"   Color="#888888"/>
        <SolidColorBrush x:Key="ActiveBgBrush"  Color="#1A3855"/>

        <!-- Base button -->
        <Style x:Key="BaseBtn" TargetType="Button">
            <Setter Property="Focusable"        Value="False"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="FontFamily"       Value="Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MiniBtn" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height"     Value="20"/>
        </Style>

        <!-- Menu row: DataTriggers for active state built in -->
        <Style x:Key="MenuRowP4"  TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background"     Value="Transparent"/>
            <Setter Property="Height"         Value="28"/>
            <Setter Property="FontSize"       Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"        Value="10,0,0,0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#333333"/>
                </Trigger>
                <DataTrigger Binding="{Binding ShowBeta}" Value="True">
                    <Setter Property="Background" Value="{StaticResource ActiveBgBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource BlueBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MenuRowP3"  TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background"     Value="Transparent"/>
            <Setter Property="Height"         Value="28"/>
            <Setter Property="FontSize"       Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"        Value="10,0,0,0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#333333"/>
                </Trigger>
                <DataTrigger Binding="{Binding ShowAlpha}" Value="True">
                    <Setter Property="Background" Value="{StaticResource ActiveBgBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource BlueBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MenuRowZH" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background"     Value="Transparent"/>
            <Setter Property="Height"         Value="28"/>
            <Setter Property="FontSize"       Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"        Value="10,0,0,0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#333333"/>
                </Trigger>
                <DataTrigger Binding="{Binding IsZH}" Value="True">
                    <Setter Property="Background" Value="{StaticResource ActiveBgBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource BlueBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MenuRowJP" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background"     Value="Transparent"/>
            <Setter Property="Height"         Value="28"/>
            <Setter Property="FontSize"       Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"        Value="10,0,0,0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#333333"/>
                </Trigger>
                <DataTrigger Binding="{Binding IsJP}" Value="True">
                    <Setter Property="Background" Value="{StaticResource ActiveBgBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource BlueBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MenuRowEN" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
            <Setter Property="Background"     Value="Transparent"/>
            <Setter Property="Height"         Value="28"/>
            <Setter Property="FontSize"       Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"        Value="10,0,0,0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#333333"/>
                </Trigger>
                <DataTrigger Binding="{Binding IsEN}" Value="True">
                    <Setter Property="Background" Value="{StaticResource ActiveBgBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource BlueBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="{Binding BgColor, Converter={StaticResource ColorToBrush}}" CornerRadius="4">
        <Grid>
            <!-- Drag bar -->
            <Border Height="30" VerticalAlignment="Top"
                    Background="{StaticResource DragBrush}"
                    CornerRadius="4,4,0,0"
                    MouseLeftButtonDown="DragBar_MouseDown">
                <Grid>
                    <!-- Left: RESET -->
                    <Button Content="RESET" Width="52" Background="#CC2222"
                            HorizontalAlignment="Left" VerticalAlignment="Center"
                            Margin="6,0,0,0"
                            Style="{StaticResource MiniBtn}"
                            Command="{Binding CmdReset}"/>
                    <!-- Right: minimize, gear, close -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Center" Margin="0,0,6,0">
                        <Button Width="24" Margin="0,0,4,0"
                                Command="{Binding CmdMinimize}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource MiniBtn}">
                                    <Setter Property="Content"    Value="▲"/>
                                    <Setter Property="Background" Value="#333333"/>
                                    <Setter Property="Foreground" Value="#BBBBBB"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMinimized}" Value="True">
                                            <Setter Property="Content" Value="▼"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="⚙" Width="24" Background="#333333" Foreground="#BBBBBB"
                                Style="{StaticResource MiniBtn}" Margin="0,0,4,0"
                                Command="{Binding CmdToggleMenu}"/>
                        <Button Content="✕" Width="22" Background="#661111"
                                Style="{StaticResource MiniBtn}"
                                Command="{Binding CmdClose}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Yellow separator — hidden when minimized -->
            <Rectangle Height="2" VerticalAlignment="Top" Margin="0,30,0,0"
                       Fill="{StaticResource YellowBrush}">
                <Rectangle.Style>
                    <Style TargetType="Rectangle">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsMinimized}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Rectangle.Style>
            </Rectangle>

            <!-- Content -->
            <Grid Margin="0,32,0,0">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsMinimized}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <v:P4View DataContext="{Binding}"
                          Visibility="{Binding ShowBeta, Converter={StaticResource BoolVis}}"/>
                <v:P3View DataContext="{Binding P3}"
                          Flipped="{Binding DataContext.AlphaFlipped, RelativeSource={RelativeSource AncestorType=Window}}"
                          Visibility="{Binding DataContext.ShowAlpha,
                              RelativeSource={RelativeSource AncestorType=Window},
                              Converter={StaticResource BoolVis}}"/>
            </Grid>

            <!-- Gear menu -->
            <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,32,2,0" Width="144"
                    Background="{StaticResource MenuBgBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" CornerRadius="3"
                    Visibility="{Binding MenuOpen, Converter={StaticResource BoolVis}}"
                    Panel.ZIndex="10">
                <StackPanel Margin="0,6,0,6">
                    <TextBlock Text="{Binding MenuMode}" Foreground="{StaticResource TextSubBrush}"
                               FontSize="9" FontWeight="Bold" TextAlignment="Center" Margin="0,0,0,4"/>
                    <Button Content="Alpha" Style="{StaticResource MenuRowP3}" Command="{Binding CmdSwitchAlpha}"/>
                    <Button Content="Beta"  Style="{StaticResource MenuRowP4}" Command="{Binding CmdSwitchBeta}"/>

                    <Separator Background="#444444" Margin="8,6"/>

                    <TextBlock Text="{Binding MenuLang}" Foreground="{StaticResource TextSubBrush}"
                               FontSize="9" FontWeight="Bold" TextAlignment="Center" Margin="0,0,0,4"/>
                    <Button Content="中文 ZH"    Style="{StaticResource MenuRowZH}" Command="{Binding CmdLangZH}"/>
                    <Button Content="日本語 JP"   Style="{StaticResource MenuRowJP}" Command="{Binding CmdLangJP}"/>
                    <Button Content="English EN" Style="{StaticResource MenuRowEN}" Command="{Binding CmdLangEN}"/>

                    <Separator Background="#444444" Margin="8,6"/>

                    <TextBlock Text="{Binding MenuOpacity}" Foreground="{StaticResource TextSubBrush}"
                               FontSize="9" FontWeight="Bold" TextAlignment="Center" Margin="0,0,0,4"/>
                    <Grid Margin="8,0,8,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="38"/>
                        </Grid.ColumnDefinitions>
                        <Slider Grid.Column="0" Minimum="0" Maximum="100"
                                Value="{Binding OpacityPct, Mode=TwoWay}"
                                VerticalAlignment="Center" Focusable="False"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding OpacityPct, StringFormat={}{0}%}"
                                   Foreground="{StaticResource YellowBrush}"
                                   FontSize="10" FontWeight="Bold"
                                   VerticalAlignment="Center" TextAlignment="Right"/>
                    </Grid>

                    <Separator Background="#444444" Margin="8,6"/>

                    <Button Content="{Binding MenuResetSize}" Margin="8,4,8,2" Height="24"
                            Background="#333333" Foreground="#AAAAAA"
                            FontSize="10" FontWeight="Bold"
                            Focusable="False" FocusVisualStyle="{x:Null}" Cursor="Hand"
                            Command="{Binding CmdResetSize}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="#555555" BorderThickness="1" CornerRadius="3">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Separator Background="#444444" Margin="8,6"/>

                    <!-- Lock size toggle -->
                    <Button Content="{Binding MenuLock}" Command="{Binding CmdToggleLock}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource BaseBtn}">
                                <Setter Property="Background"     Value="Transparent"/>
                                <Setter Property="Height"         Value="28"/>
                                <Setter Property="FontSize"       Value="11"/>
                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                <Setter Property="Padding"        Value="10,0,0,0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#333333"/>
                                    </Trigger>
                                    <DataTrigger Binding="{Binding SizeUnlocked}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource ActiveBgBrush}"/>
                                        <Setter Property="Foreground" Value="{StaticResource BlueBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Flip toggle (only Alpha mode) -->
                    <Button Content="{Binding MenuFlip}" Command="{Binding CmdFlipAlpha}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource BaseBtn}">
                                <Setter Property="Background"     Value="Transparent"/>
                                <Setter Property="Height"         Value="28"/>
                                <Setter Property="FontSize"       Value="11"/>
                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                <Setter Property="Padding"        Value="10,0,0,0"/>
                                <Setter Property="Visibility"     Value="Collapsed"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#333333"/>
                                    </Trigger>
                                    <DataTrigger Binding="{Binding ShowAlpha}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding AlphaFlipped}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource ActiveBgBrush}"/>
                                        <Setter Property="Foreground" Value="{StaticResource BlueBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
